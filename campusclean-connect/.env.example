DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=campusclean
PORT=3000

# Set to "production" when deploying. In production the app REFUSES to start
# unless SESSION_SECRET is set to a strong, unique value (and cookies become
# secure/HTTPS-only).
NODE_ENV=development

# Generate a strong secret, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-this-in-production

# --- Email delivery for OTP codes (optional, free with Gmail) ---
# Leave SMTP_USER/SMTP_PASS blank to keep zero-setup mode (code shown in-app in
# development + logged to the server console). To send real emails:
#   1. Use a Gmail account with 2-Step Verification enabled.
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Put the 16-character app password (no spaces) in SMTP_PASS below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# OTP email is resilient by default: it uses verified TLS, and if a local
# antivirus/proxy (e.g. Avast Mail Shield) breaks certificate verification it
# automatically retries so delivery still succeeds. You normally don't need the
# line below. Set SMTP_INSECURE=true only to skip the (failing) verified attempt
# up front on such machines. On a real host without an intercepting AV, leave it off.
# SMTP_INSECURE=true

# --- Payments ---
CURRENCY=GHS
# Platform keeps this % of each successful payment; the rest goes to the cleaner.
PLATFORM_COMMISSION_PERCENT=10
# Paystack TEST keys are free and behave like live payments (Mobile Money, card,
# bank transfer) — perfect for a campus demo. Get them from your Paystack
# dashboard → Settings → API Keys & Webhooks. Leave blank to allow only the free
# "Cash on completion" method.
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
